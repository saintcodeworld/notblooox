NODE_ENV=development # Keep as development - Render handles SSL termination, so we use plain App() not SSLApp()
GAME_TICKRATE=20 # Game tickrate in Hz (20Hz = 50ms)
GAME_SCRIPT=defaultScript.ts # Script to run
PORT=8001 # Render overrides this with its own PORT env var

# Production CORS - set this to your Vercel frontend URL to restrict WebSocket connections
FRONTEND_URL=https://blox-world.vercel.app